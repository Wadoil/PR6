<Page x:Class="WpfApp1.Pages.AdminPagePerson"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="AdminPagePerson">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#ff498c51" Padding="20">
            <TextBlock x:Name="TitleTextBlock" 
                       Text="Placeholder" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Основное содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая колонка - данные сотрудника -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,20,0">
                    <Border Background="White" CornerRadius="5" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Персональные данные" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Фамилия -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Name="SurnameEntry" Height="30" Margin="0,5" Padding="5"/>

                                <!-- Имя -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Name="NameEntry" Height="30" Margin="0,5" Padding="5"/>

                                <!-- Отчество -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Name="PatronymicEntry" Height="30" Margin="0,5" Padding="5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="5" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Рабочая информация" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Должность -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Должность:" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Name="PositionEntry" Height="30" Margin="0,5" Padding="5"/>

                                <!-- Отдел -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Отдел:" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Name="DepartmentEntry" Height="30" Margin="0,5" Padding="5"/>

                                <!-- Дата найма -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата найма:" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Name="HireDateEntry" Height="30" Margin="0,5" Padding="5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="5" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Данные для входа" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Логин -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Name="LoginEntry" Height="30" Margin="0,5" Padding="5"/>

                                <!-- Пароль -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>
                                <PasswordBox Grid.Row="1" Grid.Column="1" Name="PasswordEntry" Height="30" Margin="0,5" Padding="5"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Background="White" CornerRadius="5" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Фотография" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <Image Source="/Resources/logo.png" Width="150" Height="150"/>

                            <Button Content="Загрузить фото" 
                                    Height="35" 
                                    BorderThickness="0"
                                    Margin="0,0,0,10">
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Нижняя панель с кнопками -->
        <Border Grid.Row="2" Background="White" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="SaveBtn" Content="Сохранить" 
                        Width="100" Height="35"
                        Background="#1976D2" Foreground="White"
                        BorderThickness="0" Margin="0,0,10,0"
                        Click="SaveBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Name="ClearBtn" Content="Очистить" 
                        Width="100" Height="35"
                        Background="#9E9E9E" Foreground="White"
                        BorderThickness="0" Margin="0,0,10,0"
                        Click="ClearBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Name="CancelBtn" Content="Отмена" 
                        Width="100" Height="35"
                        Background="#F44336" Foreground="White"
                        BorderThickness="0"
                        Click="CancelBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>