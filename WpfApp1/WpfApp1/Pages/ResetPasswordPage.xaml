<Page x:Class="WpfApp1.Pages.ResetPasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ResetPasswordPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="255"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="255"/>
        </Grid.ColumnDefinitions>
        <StackPanel x:Name="CodeStack" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="DataTextBlock" Text="Логин:"/>
            <TextBox x:Name="DataBox"/>
            <Button x:Name="SendCodeBtn" Content="Отправить код подтверждения" Width="240" Click="SendCodeBtn_Click"/>
            <Button x:Name="CheckCodeBtn" Content="Сбросить пароль" Width="130" Click="CheckCodeBtn_Click" Visibility="Collapsed"/>
        </StackPanel>
        <StackPanel x:Name="PasswordReset" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
            <TextBlock Text="Пароль:"/>
            <PasswordBox x:Name="PasswordBox"/>
            <TextBlock Text="Подтверждение пароля:"/>
            <PasswordBox x:Name="AgreePasswordBox"/>
            <Button Content="Сохранить новый пароль" Width="240" Click="SetNewPasswordBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
