<Page x:Class="WpfApp1.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска -->
        <StackPanel Grid.ColumnSpan="4" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBox x:Name="searcLine" Width="300" Height="30" 
                     Text="Поиск" 
                     Foreground="Gray"
                     Margin="0,0,10,0"/>
            <Button x:Name="searchBtn" Content="Поиск" Width="80" Height="30" 
                    Click="SearchBtn_Click" Margin="0,0,10,0"/>
            <Button x:Name="createBtn" Content="Создать" Width="80" Height="30" 
                    Click="CreateBtn_Click"/>
        </StackPanel>

        <!-- Список сотрудников -->
        <ListView Name="MainListView" Grid.Row="1" Grid.ColumnSpan="4" Margin="10"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,0,0,5"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5"
                            Background="White" MouseLeftButtonDown="OpenPerson"
                            Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Аватар с инициалами -->
                            <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" 
                                    Background="#E3F2FD" Margin="0,0,15,0">
                                <TextBlock Text="{Binding Initials}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center" 
                                           FontSize="16" FontWeight="Bold" 
                                           Foreground="#1976D2"/>
                            </Border>

                            <!-- ФИО -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FullName}" 
                                           FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Дополнительная информация -->
                            <StackPanel Grid.Column="2" Margin="20,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding OtherInfo}" 
                                           TextWrapping="Wrap"
                                           Foreground="#666666"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>